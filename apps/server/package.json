{
  "name": "@catavento/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration --pool=forks --poolOptions.forks.singleFork=false",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@catavento/contracts": "workspace:*",
    "@catavento/db": "workspace:*",
    "@fastify/jwt": "^10.2.0",
    "@fastify/multipart": "^10.1.0",
    "@fastify/sensible": "^6.0.0",
    "argon2": "^0.44.0",
    "csv-parse": "^7.0.1",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "fastify": "^5.10.0",
    "fastify-plugin": "^5.0.0",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.4",
    "@types/pg": "^8.11.0",
    "@vitest/coverage-v8": "^4.1.10",
    "light-my-request": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.10"
  }
}
