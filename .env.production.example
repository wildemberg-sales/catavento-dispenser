# Variáveis para docker-compose.prod.yml — copie para .env.production no
# servidor e preencha com segredos reais (NUNCA reutilize os valores de dev).
#
# Uso: docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build

# Postgres
POSTGRES_USER=catavento
POSTGRES_PASSWORD=troque-por-uma-senha-forte
POSTGRES_DB=catavento_prod
PGPOOL_MAX=10

# JWT — gere segredos fortes e diferentes dos de desenvolvimento
JWT_ACCESS_SECRET=troque-por-um-segredo-forte
JWT_REFRESH_SECRET=troque-por-outro-segredo-forte
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Motor de fila / abandono
ABANDONMENT_CHECK_INTERVAL_MS=60000
ABANDONMENT_TIMEOUT_MINUTES=15

# Servidor
LOG_LEVEL=info

# Storage — STORAGE_PUBLIC_BASE_URL precisa ser a URL externamente acessível
# que serve /uploads/* (ex.: https://api.seudominio.com/uploads)
STORAGE_PUBLIC_BASE_URL=https://troque-pelo-dominio-real.com/uploads
MAX_IMAGE_SIZE_BYTES=5242880
MAX_IMAGES_PER_PRODUCT=8
ANALYTICS_MAX_RANGE_DAYS=90
